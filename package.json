{
  "name": "@guildpass/sdk",
  "version": "0.1.0",
  "description": "The official TypeScript SDK for GuildPass, a Web3 membership and access-control protocol.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc src/index.ts"
  },
  "keywords": [
    "web3",
    "membership",
    "access-control",
    "guild",
    "token-gating",
    "sdk",
    "typescript"
  ],
  "author": "GuildPass",
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.2",
    "typedoc": "^0.25.8",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
